"""Constraint boundaries for the psychohistory daemon.

These are not "checked" at runtime - they are embedded in types.
Invalid states cannot be constructed because the type constructors
enforce these bounds.
"""

from decimal import Decimal
from typing import Literal


# === POSITION CONSTRAINTS === (PRD-compliant risk limits)

# Maximum allocation to any single symbol
MAX_SINGLE_POSITION: Decimal = Decimal('0.20')  # 15% max per position

# Maximum allocation to correlated assets (e.g., all crypto)
MAX_CORRELATED: Decimal = Decimal('0.50')  # 50% max correlated exposure

# Minimum cash reserve (always maintained)
MIN_CASH: Decimal = Decimal('0.15')  # 20% cash reserve

# Rebalance threshold (drift before rebalance action exists)
REBALANCE_THRESHOLD: Decimal = Decimal('0.05')  # 5% drift


# === EXIT CONSTRAINTS === (PRD-compliant stop-loss and take-profit)

# Per-position stop loss
STOP_LOSS: Decimal = Decimal('0.05')  # 5% stop loss per position

# Per-position take profit (partial exit)
TAKE_PROFIT_PARTIAL: Decimal = Decimal('0.15')  # 15% take profit trigger
TAKE_PROFIT_PARTIAL_SIZE: Decimal = Decimal('0.70')  # 70% partial exit on take profit

# Portfolio-level max drawdown
MAX_DRAWDOWN: Decimal = Decimal('0.10')  # 10% max portfolio drawdown


# === CIRCUIT BREAKERS === (PRD-compliant loss limits)

# Daily loss limit (triggers HaltRegime until next trading day)
MAX_DAILY_LOSS: Decimal = Decimal('0.10')  # 10% daily loss limit

# Weekly loss limit (triggers HaltRegime until next week)
MAX_WEEKLY_LOSS: Decimal = Decimal('0.25')  # 25% weekly loss limit

# Cooldown after stop loss (skip N signals before new entries)
COOLDOWN_AFTER_LOSS: int = 3  # 3 signal cooldown after stop loss


# === SIGNAL REQUIREMENTS === (PRD-compliant confluence gating)

# Minimum confluence score for execution
MIN_CONFLUENCE_SCORE: Decimal = Decimal('0.10')  # 70% minimum confluence

# Minimum agreeing layers (Trinity Minimum)
MIN_AGREEING_LAYERS: int = 2  # At least 3 layers must agree

# High confluence threshold (for alerts)
HIGH_CONFLUENCE_THRESHOLD: Decimal = Decimal('0.30')  # 30%


# === LAYER WEIGHTS ===

LAYER_WEIGHTS: dict[str, Decimal] = {
    'astrology': Decimal('1.0'),
    'sacred_geometry': Decimal('1.0'),
    'numerology': Decimal('0.8'),
    'archetype': Decimal('1.0'),
    'phoenix': Decimal('1.2'),
    'gematria': Decimal('0.5'),
}

# Layers that can force ResearchRegime or HaltRegime
VETO_LAYERS: set[str] = {'astrology', 'archetype', 'phoenix'}


# === FOCUS ASSETS ===

# Primary: High-volatility crypto (24/7 markets)
PRIMARY_ASSETS: list[str] = ['SOL', 'AVAX', 'LINK', 'DOGE', 'MATIC']

# Secondary: Tech stocks with earnings volatility
SECONDARY_ASSETS: list[str] = ['NVDA', 'COIN', 'MSTR', 'MARA', 'HOOD']

# Tertiary: Meme/sentiment plays (requires archetype confirmation)
TERTIARY_ASSETS: list[str] = ['GME', 'AMC']

# Index hedges
HEDGE_ASSETS: list[str] = ['QQQ', 'IWM', 'SQQQ']

# All tradeable assets
ALL_ASSETS: list[str] = PRIMARY_ASSETS + SECONDARY_ASSETS + TERTIARY_ASSETS + HEDGE_ASSETS

# Crypto assets (for correlation grouping)
CRYPTO_ASSETS: set[str] = {'BTC', 'ETH', 'SOL', 'AVAX', 'LINK', 'DOGE', 'MATIC'}

# BTC-correlated equities
BTC_CORRELATED: set[str] = {'MSTR', 'MARA', 'COIN'}


# === TIMING === (PRD-compliant cycle intervals)

# Daemon cycle interval
CYCLE_INTERVAL_SECONDS: int = 60  # 60 seconds between cycles

# Stale data threshold (ResearchRegime if data older than this)
STALE_DATA_THRESHOLD_SECONDS: int = 600  # 10 minutes


# === CORRELATION GROUPS ===
# Assets in same group share MAX_CORRELATED limit

CORRELATION_GROUPS: dict[str, set[str]] = {
    'crypto': CRYPTO_ASSETS | BTC_CORRELATED,
    'tech': {'NVDA', 'QQQ'},
    'meme': {'GME', 'AMC', 'HOOD'},
}


# === CATALYST BLACKOUTS ===
# Dates when ResearchRegime is forced regardless of signals

FOMC_DATES_2026: list[str] = [
    '2026-01-29',
    '2026-03-19',
    '2026-05-07',
    '2026-06-18',
    '2026-07-30',
    '2026-09-17',
    '2026-11-05',
    '2026-12-17',
]

# Days before/after FOMC to blackout
FOMC_BLACKOUT_DAYS: int = 2  # 2 days before/after FOMC


# === EARNINGS DATES (update as needed) ===

EARNINGS_DATES: dict[str, str] = {
    'NVDA': '2026-02-26',
    'COIN': '2026-02-15',
}

# Days before earnings to increase position limits
EARNINGS_BOOST_DAYS: int = 2
EARNINGS_BOOST_MULTIPLIER: Decimal = Decimal('1.5')


# === ALERT THRESHOLDS ===

# P&L thresholds for alerts
ALERT_PROFIT_THRESHOLD: Decimal = Decimal('0.10')  # 10% gain
ALERT_LOSS_THRESHOLD: Decimal = Decimal('0.03')  # 3% loss (before stop)


# === CONSTRAINT SUMMARY ===

class Constraints:
    """Immutable constraint container for injection."""

    def __init__(
        self,
        max_single_position: Decimal = MAX_SINGLE_POSITION,
        max_correlated: Decimal = MAX_CORRELATED,
        min_cash: Decimal = MIN_CASH,
        stop_loss: Decimal = STOP_LOSS,
        take_profit_partial: Decimal = TAKE_PROFIT_PARTIAL,
        max_drawdown: Decimal = MAX_DRAWDOWN,
        max_daily_loss: Decimal = MAX_DAILY_LOSS,
        max_weekly_loss: Decimal = MAX_WEEKLY_LOSS,
        cooldown_after_loss: int = COOLDOWN_AFTER_LOSS,
        min_confluence_score: Decimal = MIN_CONFLUENCE_SCORE,
        min_agreeing_layers: int = MIN_AGREEING_LAYERS,
    ):
        self.max_single_position = max_single_position
        self.max_correlated = max_correlated
        self.min_cash = min_cash
        self.stop_loss = stop_loss
        self.take_profit_partial = take_profit_partial
        self.max_drawdown = max_drawdown
        self.max_daily_loss = max_daily_loss
        self.max_weekly_loss = max_weekly_loss
        self.cooldown_after_loss = cooldown_after_loss
        self.min_confluence_score = min_confluence_score
        self.min_agreeing_layers = min_agreeing_layers

    @classmethod
    def default(cls) -> 'Constraints':
        """Return PRD-compliant constraints (current default).

        All risk limits active:
        - max_single_position = 15%
        - max_correlated = 50%
        - min_cash = 20%
        - stop_loss = 5%, take_profit = 15%
        - max_drawdown = 10%
        - daily/weekly loss limits active
        - cooldown_after_loss = 3 signals
        - min_confluence = 70%, min_layers = 3
        """
        return cls()

    @classmethod
    def prd(cls) -> 'Constraints':
        """Canonical PRD-compliant factory. Same as default."""
        return cls()
